<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.milo.prac.commoncode.mapper.CodeGroupMapper">

  <select id="findAll" resultType="CodeGroupDto">
    SELECT
      GROUP_CODE,
      GROUP_NAME,
      DESCRIPTION,
      CREATED_BY,
      CREATED_AT,
      UPDATED_BY,
      UPDATED_AT
    FROM
      TB_CODE_GROUP
  </select>

</mapper>